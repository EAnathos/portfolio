---
import Layout from '../layouts/Layout.astro';
import PhotographyContent from '../components/photography/PhotographyContent.astro';
import { getTranslations } from '../i18n/translations';

const t = getTranslations('fr');
const tp = t.photography_page;
---

<Layout title={tp.title} description={tp.description} lang="fr">
	<PhotographyContent {t} currentPath="/photographie" homeHref="/" />
</Layout>
