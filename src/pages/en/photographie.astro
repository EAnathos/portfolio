---
import Layout from '../../layouts/Layout.astro';
import PhotographyContent from '../../components/photography/PhotographyContent.astro';
import { getTranslations } from '../../i18n/translations';

const t = getTranslations('en');
const tp = t.photography_page;
---

<Layout title={tp.title} description={tp.description} lang="en">
	<PhotographyContent {t} currentPath="/en/photographie" homeHref="/en" />
</Layout>
