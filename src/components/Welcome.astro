---
import SiteHeader from './sections/SiteHeader.astro';
import HeroSection from './sections/HeroSection.astro';
import AboutSection from './sections/AboutSection.astro';
import SkillsSection from './sections/SkillsSection.astro';
import ProjectsSection from './sections/ProjectsSection.astro';
import PhotoSection from './sections/PhotoSection.astro';
import ContactSection from './sections/ContactSection.astro';
import SiteFooter from './sections/SiteFooter.astro';
import { getLocalizedSkillGroups, getLocalizedGear, getLocalizedProjects } from '../data/portfolioData';
import type { Translations } from '../i18n/translations';

const { t } = Astro.props as { t: Translations };

const skillGroups = getLocalizedSkillGroups(t.skills.groups);
const gear = getLocalizedGear({ body: t.photo.gear_body, lens: t.photo.gear_lens, flash: t.photo.gear_flash });
const projects = getLocalizedProjects(t.projects.descriptions);
---

<div class="relative overflow-hidden">
	<div class="pointer-events-none absolute -left-40 top-[-120px] h-[360px] w-[360px] rounded-full bg-[rgba(44,166,255,0.18)] blur-[140px]"></div>
	<div class="pointer-events-none absolute right-[-120px] top-[120px] h-[340px] w-[340px] rounded-full bg-[rgba(10,61,154,0.35)] blur-[160px]"></div>

	<SiteHeader {t} />
	<HeroSection {t} />
	<AboutSection {t} />
	<SkillsSection groups={skillGroups} {t} />
	<ProjectsSection projects={projects} {t} />
	<PhotoSection gear={gear} {t} />
	<ContactSection {t} />
	<SiteFooter {t} />
</div>
