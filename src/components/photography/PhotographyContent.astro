---
import '../../styles/photography.css';
import SiteHeader from '../sections/SiteHeader.astro';
import SiteFooter from '../sections/SiteFooter.astro';
import PhotoHero from './PhotoHero.astro';
import PhotographyCard from '../cards/PhotographyCard.astro';
import { photographyCollections, heroItem } from '../../data/photography';
import type { Translations } from '../../i18n/translations';

interface Props {
	t: Translations;
	currentPath: string;
	homeHref: string;
}

const { t, currentPath, homeHref } = Astro.props as Props;
const tp = t.photography_page;

const navLinks = [
	{ href: homeHref, label: t.nav.home },
	{ href: '#macrophotography', label: t.nav.macro },
	{ href: '#other', label: t.nav.other },
	{ href: '#contact', label: t.nav.contact }
];

const collectionMeta: Record<string, { title: string; desc: string }> = {
	macrophotography: { title: tp.macro_title, desc: tp.macro_desc },
	other: { title: tp.other_title, desc: tp.other_desc }
};
---

<div class="photo-page relative">
	<SiteHeader navLinks={navLinks} {t} currentPath={currentPath} />

	{heroItem && <PhotoHero item={heroItem} {t} />}

	<main class="relative z-[1] mx-auto w-full max-w-6xl px-6">
		<!-- Intro / overview -->
		<section class="p-reveal border-b border-[color:var(--p-line)] py-16 md:py-20">
			<p class="p-eyebrow">{tp.label}</p>
			<p class="p-display mt-4 max-w-3xl text-3xl leading-snug text-[color:var(--p-ink-0)] md:text-4xl">
				{tp.intro}
			</p>
			<div class="mt-8 flex flex-wrap items-center gap-3">
				<a
					class="photo-outline"
					href="https://www.inaturalist.org/people/anathos_"
					target="_blank"
					rel="noreferrer"
				>
					iNaturalist
				</a>
				<a
					class="photo-outline"
					href="https://www.instagram.com/anathos_microcosmos/"
					target="_blank"
					rel="noreferrer"
				>
					Instagram
				</a>
			</div>
		</section>

		<!-- Collections -->
		{photographyCollections.map((collection) => (
			<section id={collection.id} class="py-16 md:py-20">
				<div class="mb-10 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
					<h2 class="p-display p-underline text-3xl text-[color:var(--p-ink-0)] md:text-4xl">
						{collectionMeta[collection.id].title}
					</h2>
					<p class="max-w-xl text-sm text-[color:var(--p-ink-1)]">
						{collectionMeta[collection.id].desc}
					</p>
				</div>
				<div class="photo-masonry">
					{collection.items.map((item) => (
						<PhotographyCard item={item} {t} />
					))}
				</div>
			</section>
		))}

		<!-- Contact -->
		<section
			id="contact"
			class="p-reveal my-16 rounded-[28px] border border-[color:var(--p-line)] bg-[color:var(--p-surface)] p-8 md:my-20 md:flex md:justify-between md:gap-10 md:p-10"
		>
			<div class="max-w-md space-y-3">
				<p class="p-eyebrow">{t.contact.label}</p>
				<h2 class="p-display text-3xl text-[color:var(--p-ink-0)]">{tp.contact_heading}</h2>
				<p class="text-[color:var(--p-ink-1)]">{tp.contact_text}</p>
				<p class="text-sm text-[color:var(--p-ink-1)]">
					Instagram :
					<a
						href="https://www.instagram.com/anathos_microcosmos/"
						target="_blank"
						rel="noopener"
						class="underline hover:text-[color:var(--p-amber)]"
					>
						@anathos_microcosmos
					</a>
				</p>
			</div>
			<form
				class="mt-6 w-full max-w-md space-y-4 md:mt-0"
				method="post"
				action="/api/contact"
				data-contact-form
			>
				<div>
					<label class="p-label" for="email-photo">{t.contact.email_label}</label>
					<input
						id="email-photo"
						name="email"
						type="email"
						placeholder="you@email.com"
						required
						class="photo-input"
					/>
				</div>
				<div>
					<label class="p-label" for="subject-photo">{t.contact.subject_label}</label>
					<input
						id="subject-photo"
						name="subject"
						type="text"
						placeholder={t.contact.subject_placeholder}
						required
						class="photo-input"
					/>
				</div>
				<div>
					<label class="p-label" for="message-photo">{t.contact.message_label}</label>
					<textarea
						id="message-photo"
						name="message"
						rows="4"
						placeholder={t.contact.message_placeholder}
						required
						class="photo-input"
					></textarea>
				</div>
				<p class="text-sm text-[color:var(--p-ink-2)]" data-contact-status aria-live="polite"></p>
				<div class="flex flex-wrap gap-3">
					<button type="submit" class="photo-cta">{t.contact.submit}</button>
					<a href={homeHref} class="photo-outline">{tp.contact_cta}</a>
				</div>
			</form>
		</section>
	</main>

	<SiteFooter {t} />
</div>

<script
	define:vars={{ sending: t.contact.sending, success: t.contact.success, error: t.contact.error }}
>
	const form = document.querySelector('[data-contact-form]');
	const statusEl = document.querySelector('[data-contact-status]');

	if (form && statusEl) {
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			statusEl.textContent = sending;

			const response = await fetch(form.action, {
				method: 'POST',
				body: new FormData(form)
			});

			if (response.ok) {
				form.reset();
				statusEl.textContent = success;
				return;
			}

			const data = await response.json().catch(() => ({}));
			statusEl.textContent = data?.message || error;
		});
	}
</script>

<script>
	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	// --- Scroll reveals (blur-to-focus, staggered) ---------------------------
	const revealTargets = document.querySelectorAll('.p-reveal, .p-underline');
	if (reduceMotion || !('IntersectionObserver' in window)) {
		revealTargets.forEach((el) => el.classList.add('is-visible'));
	} else {
		const observer = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
						obs.unobserve(entry.target);
					}
				});
			},
			{ rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
		);
		revealTargets.forEach((el) => observer.observe(el));
	}

	// --- Card 3D tilt on pointer --------------------------------------------
	if (!reduceMotion && window.matchMedia('(hover: hover)').matches) {
		document.querySelectorAll('[data-tilt]').forEach((card) => {
			const el = card as HTMLElement;
			el.addEventListener('pointermove', (event) => {
				const rect = el.getBoundingClientRect();
				const px = (event.clientX - rect.left) / rect.width - 0.5;
				const py = (event.clientY - rect.top) / rect.height - 0.5;
				el.style.setProperty('--tilt-y', `${px * 6}deg`);
				el.style.setProperty('--tilt-x', `${-py * 6}deg`);
			});
			el.addEventListener('pointerleave', () => {
				el.style.setProperty('--tilt-y', '0deg');
				el.style.setProperty('--tilt-x', '0deg');
			});
		});
	}

	// --- Lightbox: open, close, prev/next, swipe, focus restore --------------
	const dialogs = Array.from(
		document.querySelectorAll('[data-photo-dialog]')
	) as HTMLDialogElement[];
	let lastTrigger: HTMLElement | null = null;

	function siblingDialog(dialog: HTMLDialogElement, direction: number): HTMLDialogElement | null {
		const collection = dialog.getAttribute('data-photo-collection');
		const index = Number(dialog.getAttribute('data-photo-index'));
		const group = dialogs.filter(
			(candidate) => candidate.getAttribute('data-photo-collection') === collection
		);
		if (!group.length || Number.isNaN(index)) return null;
		const next = (index + direction + group.length) % group.length;
		return group[next] ?? null;
	}

	function navigate(dialog: HTMLDialogElement, direction: number) {
		const sibling = siblingDialog(dialog, direction);
		if (sibling) {
			dialog.close();
			sibling.showModal();
		}
	}

	document.querySelectorAll('[data-open-photo]').forEach((button) => {
		button.addEventListener('click', () => {
			const id = button.getAttribute('data-open-photo');
			const dialog = id ? (document.getElementById(id) as HTMLDialogElement | null) : null;
			if (dialog instanceof HTMLDialogElement && typeof dialog.showModal === 'function') {
				lastTrigger = button as HTMLElement;
				dialog.showModal();
			}
		});
	});

	dialogs.forEach((dialog) => {
		// Click outside the panel closes.
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});

		// Restore focus to the card that opened it.
		dialog.addEventListener('close', () => {
			lastTrigger?.focus();
		});

		dialog.querySelector('[data-photo-prev]')?.addEventListener('click', () =>
			navigate(dialog, -1)
		);
		dialog.querySelector('[data-photo-next]')?.addEventListener('click', () =>
			navigate(dialog, 1)
		);

		dialog.addEventListener('keydown', (event) => {
			if (!(event instanceof KeyboardEvent)) return;
			if (event.key === 'ArrowRight') {
				event.preventDefault();
				navigate(dialog, 1);
			} else if (event.key === 'ArrowLeft') {
				event.preventDefault();
				navigate(dialog, -1);
			}
		});

		// Touch swipe on the image stage.
		const stage = dialog.querySelector('.photo-dialog__stage');
		let startX = 0;
		stage?.addEventListener(
			'touchstart',
			(event) => {
				startX = (event as TouchEvent).changedTouches[0].clientX;
			},
			{ passive: true }
		);
		stage?.addEventListener(
			'touchend',
			(event) => {
				const dx = (event as TouchEvent).changedTouches[0].clientX - startX;
				if (Math.abs(dx) > 60) navigate(dialog, dx < 0 ? 1 : -1);
			},
			{ passive: true }
		);
	});
</script>
