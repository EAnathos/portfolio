---
import { Image } from 'astro:assets';
import heroImage from '../../assets/me.png';
import type { Translations } from '../../i18n/translations';

const { t } = Astro.props as { t: Translations };
---

<section class="relative z-10 mx-auto grid w-full max-w-6xl items-center gap-12 px-6 pb-20 pt-10 md:grid-cols-[1.15fr_0.85fr]">
	<div class="space-y-8">
		<div class="fade-up">
			<h1 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">
				{t.hero.greeting} <span class="text-[color:var(--accent-0)]">EAnathos</span>.
			</h1>
			<p class="mt-4 max-w-xl text-lg text-[color:var(--ink-1)]">
				{t.hero.subtitle}
			</p>
		</div>
		<div class="fade-up fade-up-1 flex flex-wrap gap-4">
			<a
				href="#projets"
				class="rounded-full bg-[color:var(--accent-0)] px-6 py-3 text-sm font-semibold text-[#040b1e] transition hover:brightness-110"
			>
				{t.hero.cta_projects}
			</a>
			<div class="group relative">
				<span
					class="cursor-not-allowed rounded-full border border-[rgba(44,166,255,0.15)] px-6 py-3 text-sm font-semibold text-[color:var(--ink-2)] opacity-40 select-none inline-block"
					aria-disabled="true"
				>
					{t.hero.cta_cv}
				</span>
				<div class="pointer-events-none absolute bottom-full left-1/2 mb-3 -translate-x-1/2 whitespace-nowrap rounded-xl border border-[rgba(44,166,255,0.25)] bg-[rgba(6,15,36,0.95)] px-4 py-2.5 text-xs font-medium text-[color:var(--ink-1)] opacity-0 shadow-lg transition-opacity duration-200 group-hover:opacity-100">
					{t.hero.cv_unavailable}
					<span class="absolute left-1/2 top-full -translate-x-1/2 border-4 border-transparent border-t-[rgba(44,166,255,0.25)]"></span>
				</div>
			</div>
		</div>
	</div>
	<div class="fade-up fade-up-1 relative">
		<div class="float-slow absolute -left-6 -top-6 h-20 w-20 rounded-3xl border border-[rgba(44,166,255,0.45)] bg-[rgba(44,166,255,0.12)]"></div>
		<div class="rounded-[36px] border border-[rgba(44,166,255,0.2)] bg-[rgba(4,10,26,0.8)] p-6 shadow-[0_40px_120px_rgba(3,8,23,0.65)]">
			<div class="overflow-hidden rounded-[28px] border border-[rgba(44,166,255,0.18)]">
				<Image
					src={heroImage}
					alt="Photo de EAnathos"
					width={640}
					height={480}
					loading="eager"
					class="h-[320px] w-full object-cover"
				/>
			</div>
		</div>
	</div>
</section>
