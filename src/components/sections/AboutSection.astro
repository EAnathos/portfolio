---
import type { Translations } from '../../i18n/translations';
const { t } = Astro.props as { t: Translations };
---

<section id="a-propos" class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-20">
	<div class="grid gap-10">
		<div class="fade-up space-y-5">
			<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--ink-2)]">{t.about.label}</p>
			<h2 class="text-3xl font-semibold">{t.about.title}</h2>
			<p class="text-[color:var(--ink-1)]">{t.about.p1}</p>
			<p class="text-[color:var(--ink-1)]">{t.about.p2}</p>
		</div>
	</div>
</section>
