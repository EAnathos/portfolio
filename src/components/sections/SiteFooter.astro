---
import type { Translations } from '../../i18n/translations';
const { t } = Astro.props as { t: Translations };
---

<footer class="relative z-10 border-t border-[rgba(44,166,255,0.12)]">
	<div class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-4 px-6 py-6 text-sm text-[color:var(--ink-2)] md:flex-row">
		<p>{t.footer.rights}</p>
		<p><a href="mailto:eanathos@gmail.com" class="transition hover:text-[color:var(--ink-0)]">eanathos@gmail.com</a></p>
	</div>
</footer>
