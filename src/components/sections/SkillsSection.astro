---
import type { SkillGroup } from '../../data/portfolioData';
import type { Translations } from '../../i18n/translations';
import SkillGroupCard from '../cards/SkillGroupCard.astro';

const { groups, t } = Astro.props as { groups: SkillGroup[]; t: Translations };
---

<section id="competences" class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-20">
	<div class="fade-up flex items-center justify-between">
		<div>
			<p class="text-xs uppercase tracking-[0.35em] text-[color:var(--ink-2)]">{t.skills.label}</p>
			<h2 class="mt-3 text-3xl font-semibold">{t.skills.title}</h2>
		</div>
		<p class="hidden text-sm text-[color:var(--ink-2)] md:block">{t.skills.evolving}</p>
	</div>
	<div class="mt-10 grid gap-6 md:grid-cols-2">
		{groups.map((group) => (
			<SkillGroupCard group={group} />
		))}
	</div>
</section>
